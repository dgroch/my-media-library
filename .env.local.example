# ---------------------------------------------------------------------------
# Notion credentials
# ---------------------------------------------------------------------------
# Internal integration token from https://www.notion.so/my-integrations
# (starts with "ntn_" or "secret_"). The integration must be granted access to
# the Brand Asset Manifest database AND the Collections database.
NOTION_TOKEN=

# The Brand Asset Manifest database. The app auto-resolves the data source from
# this database id, so you normally only need to set this one.
NOTION_ASSETS_DATABASE_ID=357fdc24-425f-81ed-805c-c4f9aff0665f
# Optional: set explicitly to skip the auto-resolve lookup.
# NOTION_ASSETS_DATA_SOURCE_ID=357fdc24-425f-81a2-8785-000b04ce37e3

# ---------------------------------------------------------------------------
# Collections database (for saved/shareable collections)
# ---------------------------------------------------------------------------
# Run `npm run setup:collections` once to create this database and have its id
# written here automatically. The parent page defaults to the "Assets" page.
NOTION_COLLECTIONS_DATABASE_ID=
# NOTION_COLLECTIONS_DATA_SOURCE_ID=
NOTION_COLLECTIONS_PARENT_PAGE_ID=352fdc24-425f-8088-930c-c5c1ff6afa95

# ---------------------------------------------------------------------------
# API access control (optional)
# ---------------------------------------------------------------------------
# Leave unset to keep the public, no-login behaviour: anyone can create a
# collection (this is what the in-browser "Save collection" button relies on).
# Set a secret to require `Authorization: Bearer <token>` on POST /api/collections
# — useful when exposing the API to agents/automation and you want writes
# private. Note: enabling it disables the in-browser save button (the browser
# has nowhere safe to hold the secret). Reads stay public either way.
# API_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Semantic search (embeddings)
# ---------------------------------------------------------------------------
# Used by `npm run build:index` (to embed every asset) and at query time (to
# embed the search box text). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=512
# ASSET_INDEX_PATH=data/asset-index.json
# Index build resilience (used by build:index):
# EMBED_PACE_MS=1100        # delay between embedding batches (stay under TPM)
# EMBED_MAX_RETRIES=8       # retries on 429/5xx before giving up

# ---------------------------------------------------------------------------
# Asset uploads (POST /api/assets)
# ---------------------------------------------------------------------------
# Required to enable uploads: callers must send `Authorization: Bearer <token>`
# on POST /api/assets and PATCH /api/assets/:id. Uploads stay disabled (503)
# until this is set. Run `npm run setup:upload` once to add the human-context
# properties to the Manifest.
# ASSET_LIBRARY_TOKEN=
# Public base URL the brand CDN serves uploaded originals from (required for
# uploads; no trailing slash). Must map to the R2 bucket + prefix below.
# ASSET_CDN_BASE_URL=https://cdn.example.com/figandbloom/asset-manifest
# Optional overrides:
# ASSET_STORAGE_PREFIX=figandbloom/asset-manifest/
# ASSET_R2_BUCKET=            # defaults to R2_BUCKET
# ASSET_MAX_BYTES=26214400    # 25 MB
# ASSET_SIMILAR_DISTANCE=6    # pHash Hamming distance for "similar"
# Derived objects (PUT /api/derived — render cache tier; not brand assets):
# ASSET_DERIVED_PREFIX=derived/
# ASSET_DERIVED_CDN_BASE_URL=https://cdn.example.com/derived
#
# In-app upload/review UI: the browser exchanges ASSET_LIBRARY_TOKEN once at
# POST /api/session for an httpOnly session cookie (the raw token never reaches
# client JS), so /upload and /uploads work without a per-call bearer header.

# ---------------------------------------------------------------------------
# Gemini vision manifesting (AI enrichment on photo upload)
# ---------------------------------------------------------------------------
# When configured, POST /api/assets runs each uploaded photo through a Gemini
# vision model and writes the AI channel (Overall Description, Visual Tags,
# Mood Tone, …). Best-effort: if unset or a call fails, the upload still
# succeeds — just without enrichment. Mirrors the brand-asset-manifesting skill.
# Provider "google" (default) uses Google's Generative Language API; "openrouter"
# uses OpenRouter.
# GEMINI_PROVIDER=google
# GEMINI_API_KEY=                       # google native (or GOOGLE_API_KEY)
# OPENROUTER_API_KEY=                   # when GEMINI_PROVIDER=openrouter
# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash         # openrouter default: google/gemini-3-flash-preview
# PRODUCT_CLASSIFICATION_ENABLED=true   # also suggest the catalogue product
# GEMINI_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Cloudflare R2 — prebuilt search index storage + uploaded originals
# ---------------------------------------------------------------------------
# The reindex cron job uploads the index here (npm run upload:index) and app
# deploys download it (npm run fetch:index), so deploys never re-embed. Create
# a bucket and an R2 API token (S3 credentials) in the Cloudflare dashboard.
# The web service needs read access — read/WRITE when asset uploads are
# enabled (it PUTs originals); the cron job needs read/write.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional overrides:
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_INDEX_PREFIX=

# ---------------------------------------------------------------------------
# Re-index automation (cron job only)
# ---------------------------------------------------------------------------
# The web service's Render deploy hook. The reindex job POSTs to it after a
# successful upload so the new index goes live. Find it under the web service's
# Settings → Deploy Hook in the Render dashboard.
# RENDER_DEPLOY_HOOK_URL=

# ---------------------------------------------------------------------------
# Optional: override the Notion property names the app reads from the Manifest.
# Defaults match the current Brand Asset Manifest schema.
# ---------------------------------------------------------------------------
# NOTION_PROP_TITLE=Asset
# NOTION_PROP_IMAGE_URL=Preview URL
# NOTION_PROP_DESCRIPTION=Overall Description
# NOTION_PROP_ASSET_TYPE=Asset Type
# NOTION_PROP_MIME_TYPE=Mime Type
# NOTION_PROP_DRIVE_LINK=Drive Link
# Human-context properties (upload path, created by `npm run setup:upload`):
# NOTION_PROP_CONTEXT=Context
# NOTION_PROP_PEOPLE=People
# NOTION_PROP_PRODUCT=Product
# NOTION_PROP_LOCATION=Location
# NOTION_PROP_SHOOT=Shoot
# NOTION_PROP_CREDIT=Credit
# NOTION_PROP_RIGHTS=Rights
# NOTION_PROP_RIGHTS_NOTES=Rights Notes
# NOTION_PROP_TAGS=Tags
# NOTION_PROP_SOURCE=Source
# NOTION_PROP_UPLOADED_BY=Uploaded By
# NOTION_PROP_UPLOADED_AT=Uploaded At
# NOTION_PROP_SHA256=SHA256
# NOTION_PROP_PHASH=pHash
# AI-channel properties (written by Gemini manifesting on upload):
# NOTION_PROP_CONTENT_TYPE=Content Type
# NOTION_PROP_MOOD_TONE=Mood Tone
# NOTION_PROP_VISUAL_TAGS=Visual Tags
# NOTION_PROP_PEOPLE_PRESENT=People Present
# NOTION_PROP_PRODUCTS_FLOWERS=Products / Flowers
# NOTION_PROP_SETTING_LOCATION=Setting / Location
# NOTION_PROP_USABLE_FOR=Usable For
# NOTION_PROP_REORG_NOTES=Reorg Notes
# NOTION_PROP_TIMESTAMP_BEATS=Timestamp Beats
# NOTION_PROP_CONTAINS_PRODUCT=Contains Product
# NOTION_PROP_PRODUCT_NAME=Product Name
# NOTION_PROP_PRODUCT_CONFIDENCE=Product Match Confidence
